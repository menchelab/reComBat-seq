PKG_LIBS=$(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

UNAME := $(shell uname)

ifeq ($(UNAME), Darwin)
  # Check if libomp is available (via Homebrew)
  LIBOMP_PREFIX := $(shell brew --prefix libomp 2>/dev/null)
  ifneq ($(LIBOMP_PREFIX),)
    PKG_CFLAGS = -Xclang -fopenmp -I$(LIBOMP_PREFIX)/include
    PKG_CXXFLAGS = -Xclang -fopenmp -I$(LIBOMP_PREFIX)/include
    PKG_LIBS = -L$(LIBOMP_PREFIX)/lib -lomp $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
  endif
else
  PKG_CFLAGS = -fopenmp
  PKG_CXXFLAGS = -fopenmp
  PKG_LIBS = -fopenmp $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
endif
